#include "LPC17xx.h"
#include "lpc17xx_gpio.h"
#include "lpc17xx_pinsel.h"
#include "lpc17xx_exti.h"
#include "lpc17xx_timer.h"
#include "lpc17xx_adc.h"
#include "lpc17xx_gpdma.h"

#define SERVO_MASK          (1 << 0)
#define SENSOR_MASK         (1 << 1)
#define LED_ABIERTO_MASK    (1 << 5)
#define LED_CERRADO_MASK    (1 << 6)

#define SERVO_CERRADO_US    700
#define SERVO_ABIERTO_US    2300
#define UMBRAL_ADC           1800
#define UART_BAUDIOS         115200
#define UART_LSR_RDR         (1 << 0)
#define UART_LSR_THRE        (1 << 5)
#define UART_TER_TXEN        (1 << 7)
#define UART_IER_RBR         (1 << 0)
#define UART_IER_RLS         (1 << 2)
#define DMA_CANAL_ADC        0
#define CANTIDAD_MEDICIONES  5

#define CERRADA              0
#define ESPERANDO_PRESENCIA  1
#define PRESENCIA_DETECTADA  2

volatile uint32_t servo_pulso_us = SERVO_CERRADO_US;
volatile uint32_t adc_dma_mediciones[CANTIDAD_MEDICIONES] = {0};
volatile uint16_t adc_valor = 0;
volatile uint8_t adc_dma_indice = 0;
volatile uint8_t adc_dma_cantidad = 0;
volatile uint8_t estado = CERRADA;
volatile uint16_t test1 = 0;
volatile uint16_t test2 = 0;
volatile uint8_t eint_habilitada = 1;
volatile uint8_t uart_reporte_pendiente = 0;
volatile uint8_t uart_comando_pendiente = 0;
volatile uint8_t dma_error = 0;

static uint8_t comando_uart_estado = 0;


static void config_gpio_adc_eint(void);
static void config_gpdma(void);
static void iniciar_conversion_adc_dma(void);
static void config_timer_pwm(void);
static void config_timer_sensor(void);
static void config_timer_timeout(void);
static void config_timer_reporte_uart(void);
static void config_uart0(void);
static void abrir_barrera(void);
static void cerrar_barrera(void);
static void uart0_enviar_texto(const char *texto);
static void uart0_enviar_numero(uint32_t numero);
static void uart0_enviar_historial_adc(void);
static void uart0_enviar_estado(void);
static void uart0_control_eint(uint8_t habilitar);
static void uart0_procesar_dato(char dato);

int main(void)
{
    SystemCoreClockUpdate();
    config_uart0();
    uart0_enviar_texto("\r\nUART0 iniciada\r\n");

    config_gpio_adc_eint();
    config_gpdma();
    config_timer_pwm();
    config_timer_sensor();
    config_timer_timeout();
    config_timer_reporte_uart();

    EXTI_ClearEXTIFlag(EXTI_EINT0);
    NVIC_ClearPendingIRQ(EINT0_IRQn);
    NVIC_EnableIRQ(EINT0_IRQn);

    uart0_enviar_texto("\r\nControl de barrera iniciado\r\n");
    uart0_enviar_texto("Comandos disponibles: on, off\r\n");
    uart0_enviar_estado();

    while (1) {
        if (uart_comando_pendiente != 0) {
            uint8_t comando = uart_comando_pendiente;
            uart_comando_pendiente = 0;
            uart0_control_eint(comando == 1);
        }

        if (uart_reporte_pendiente != 0) {
            uart_reporte_pendiente = 0;
            uart0_enviar_estado();
        }
    }
}

static void config_gpio_adc_eint(void)
{
    PINSEL_CFG_Type pin;

    NVIC_DisableIRQ(EINT0_IRQn);
    NVIC_DisableIRQ(ADC_IRQn);

    GPIO_SetDir(0, SERVO_MASK | LED_ABIERTO_MASK | LED_CERRADO_MASK, 1);
    GPIO_SetDir(0, SENSOR_MASK, 0);
    GPIO_ClearValue(0, LED_ABIERTO_MASK);
    GPIO_SetValue(0, SERVO_MASK | LED_CERRADO_MASK);

    pin.Portnum = PINSEL_PORT_0;
    pin.Pinnum = PINSEL_PIN_23;
    pin.Funcnum = PINSEL_FUNC_1;
    pin.Pinmode = PINSEL_PINMODE_TRISTATE;
    pin.OpenDrain = PINSEL_PINMODE_NORMAL;
    PINSEL_ConfigPin(&pin);

    ADC_Init(LPC_ADC, 200000);
    ADC_ChannelCmd(LPC_ADC, ADC_CHANNEL_0, ENABLE);
    ADC_BurstCmd(LPC_ADC, DISABLE);
    ADC_IntConfig(LPC_ADC, ADC_ADINTEN0, DISABLE);
    NVIC_ClearPendingIRQ(ADC_IRQn);

    pin.Portnum = PINSEL_PORT_2;
    pin.Pinnum = PINSEL_PIN_10;
    pin.Funcnum = PINSEL_FUNC_1;
    pin.Pinmode = PINSEL_PINMODE_PULLUP;
    PINSEL_ConfigPin(&pin);

    EXTI_InitTypeDef exti;
    EXTI_Init();
    exti.EXTI_Line = EXTI_EINT0;
    exti.EXTI_Mode = EXTI_MODE_EDGE_SENSITIVE;
    exti.EXTI_polarity = EXTI_POLARITY_LOW_ACTIVE_OR_FALLING_EDGE;
    EXTI_Config(&exti);
    EXTI_ClearEXTIFlag(EXTI_EINT0);

    NVIC_SetPriority(TIMER0_IRQn, 0);
    NVIC_SetPriority(TIMER3_IRQn, 1);
    NVIC_SetPriority(DMA_IRQn, 2);
    NVIC_SetPriority(TIMER2_IRQn, 3);
    NVIC_SetPriority(EINT0_IRQn, 4);
    NVIC_ClearPendingIRQ(EINT0_IRQn);
}

static void config_gpdma(void)
{
    GPDMA_Init();
    GPDMA_ChannelCmd(DMA_CANAL_ADC, DISABLE);
    GPDMA_ClearIntPending(GPDMA_STATCLR_INTTC, DMA_CANAL_ADC);
    GPDMA_ClearIntPending(GPDMA_STATCLR_INTERR, DMA_CANAL_ADC);

    NVIC_SetPriority(DMA_IRQn, 2);
    NVIC_ClearPendingIRQ(DMA_IRQn);
    NVIC_EnableIRQ(DMA_IRQn);
}

static void iniciar_conversion_adc_dma(void)
{
    GPDMA_Channel_CFG_Type canal;

    GPDMA_ChannelCmd(DMA_CANAL_ADC, DISABLE);
    GPDMA_ClearIntPending(GPDMA_STATCLR_INTTC, DMA_CANAL_ADC);
    GPDMA_ClearIntPending(GPDMA_STATCLR_INTERR, DMA_CANAL_ADC);

    adc_dma_mediciones[adc_dma_indice] = 0;
    dma_error = 0;

    canal.ChannelNum = DMA_CANAL_ADC;
    canal.TransferSize = 1;
    canal.TransferWidth = GPDMA_WIDTH_HALFWORD;
    canal.SrcMemAddr = 0;
    canal.DstMemAddr = (uint32_t)&adc_dma_mediciones[adc_dma_indice];
    canal.TransferType = GPDMA_TRANSFERTYPE_P2M;
    canal.SrcConn = GPDMA_CONN_ADC;
    canal.DstConn = 0;
    canal.DMALLI = 0;

    if (GPDMA_Setup(&canal) == SUCCESS) {
        GPDMA_ChannelCmd(DMA_CANAL_ADC, ENABLE);
        ADC_StartCmd(LPC_ADC, ADC_START_NOW);
    } else {
        dma_error = 1;
        uart_reporte_pendiente = 1;

        if (eint_habilitada != 0) {
            EXTI_ClearEXTIFlag(EXTI_EINT0);
            NVIC_ClearPendingIRQ(EINT0_IRQn);
            NVIC_EnableIRQ(EINT0_IRQn);
        }
    }
}

static void config_timer_pwm(void)
{
    TIM_TIMERCFG_Type timer;
    TIM_MATCHCFG_Type match;

    timer.PrescaleOption = TIM_PRESCALE_USVAL;
    timer.PrescaleValue = 1;
    TIM_Init(LPC_TIM0, TIM_TIMER_MODE, &timer);
    LPC_TIM0->MCR = 0;
    LPC_TIM0->IR = 0x3F;

    match.MatchChannel = 0;
    match.IntOnMatch = ENABLE;
    match.StopOnMatch = DISABLE;
    match.ResetOnMatch = DISABLE;
    match.ExtMatchOutputType = TIM_EXTMATCH_NOTHING;
    match.MatchValue = SERVO_CERRADO_US;
    TIM_ConfigMatch(LPC_TIM0, &match);

    match.MatchChannel = 1;
    match.ResetOnMatch = ENABLE;
    match.MatchValue = 20000;
    TIM_ConfigMatch(LPC_TIM0, &match);

    NVIC_EnableIRQ(TIMER0_IRQn);
    TIM_Cmd(LPC_TIM0, ENABLE);
}

static void config_timer_sensor(void)
{
    TIM_TIMERCFG_Type timer;
    TIM_MATCHCFG_Type match;

    timer.PrescaleOption = TIM_PRESCALE_USVAL;
    timer.PrescaleValue = 1000;
    TIM_Init(LPC_TIM3, TIM_TIMER_MODE, &timer);
    LPC_TIM3->MCR = 0;
    LPC_TIM3->IR = 0x3F;

    match.MatchChannel = 0;
    match.IntOnMatch = ENABLE;
    match.StopOnMatch = DISABLE;
    match.ResetOnMatch = ENABLE;
    match.ExtMatchOutputType = TIM_EXTMATCH_NOTHING;
    match.MatchValue = 20;
    TIM_ConfigMatch(LPC_TIM3, &match);
    NVIC_EnableIRQ(TIMER3_IRQn);
}

static void config_timer_timeout(void)
{
    TIM_TIMERCFG_Type timer;
    TIM_MATCHCFG_Type match;

    timer.PrescaleOption = TIM_PRESCALE_USVAL;
    timer.PrescaleValue = 1000;
    TIM_Init(LPC_TIM2, TIM_TIMER_MODE, &timer);
    LPC_TIM2->MCR = 0;
    LPC_TIM2->IR = 0x3F;

    match.MatchChannel = 0;
    match.IntOnMatch = ENABLE;
    match.StopOnMatch = ENABLE;
    match.ResetOnMatch = ENABLE;
    match.ExtMatchOutputType = TIM_EXTMATCH_NOTHING;
    match.MatchValue = 15000;
    TIM_ConfigMatch(LPC_TIM2, &match);
    NVIC_EnableIRQ(TIMER2_IRQn);
}

static void config_timer_reporte_uart(void)
{
    TIM_TIMERCFG_Type timer;
    TIM_MATCHCFG_Type match;

    timer.PrescaleOption = TIM_PRESCALE_USVAL;
    timer.PrescaleValue = 1000;
    TIM_Init(LPC_TIM1, TIM_TIMER_MODE, &timer);
    LPC_TIM1->MCR = 0;
    LPC_TIM1->IR = 0x3F;

    match.MatchChannel = 0;
    match.IntOnMatch = ENABLE;
    match.StopOnMatch = DISABLE;
    match.ResetOnMatch = ENABLE;
    match.ExtMatchOutputType = TIM_EXTMATCH_NOTHING;
    match.MatchValue = 1000;
    TIM_ConfigMatch(LPC_TIM1, &match);

    NVIC_SetPriority(TIMER1_IRQn, 5);
    NVIC_ClearPendingIRQ(TIMER1_IRQn);
    NVIC_EnableIRQ(TIMER1_IRQn);
    TIM_Cmd(LPC_TIM1, ENABLE);
}

static void config_uart0(void)
{
    uint32_t pclk;
    uint32_t mejor_error = 0xFFFFFFFF;
    uint32_t mejor_divisor = 1;
    uint32_t mejor_mul = 1;
    uint32_t mejor_divadd = 0;
    uint32_t mul;
    uint32_t divadd;
    uint32_t divisor;
    uint32_t denominador;
    uint32_t baud_calculado;
    uint32_t error;

    NVIC_DisableIRQ(UART0_IRQn);
    NVIC_ClearPendingIRQ(UART0_IRQn);

    LPC_SC->PCONP |= (1 << 3);
    LPC_SC->PCLKSEL0 &= ~(3 << 6);
    pclk = SystemCoreClock / 4;

    LPC_PINCON->PINSEL0 &= ~((3 << 4) | (3 << 6));
    LPC_PINCON->PINSEL0 |= (1 << 4) | (1 << 6);
    LPC_PINCON->PINMODE0 &= ~((3 << 4) | (3 << 6));

    for (mul = 1; mul <= 15; mul++) {
        for (divadd = 0; divadd < mul; divadd++) {
            denominador = 16 * UART_BAUDIOS * (mul + divadd);
            divisor = ((pclk * mul) + (denominador / 2)) / denominador;

            if (divisor == 0 || divisor > 65535) {
                continue;
            }

            baud_calculado = (pclk * mul) /
                (16 * divisor * (mul + divadd));
            error = baud_calculado > UART_BAUDIOS ?
                baud_calculado - UART_BAUDIOS :
                UART_BAUDIOS - baud_calculado;

            if (error < mejor_error) {
                mejor_error = error;
                mejor_divisor = divisor;
                mejor_mul = mul;
                mejor_divadd = divadd;
            }
        }
    }

    LPC_UART0->LCR = 0x03;
    LPC_UART0->IER = 0;
    LPC_UART0->TER = 0;
    LPC_UART0->ACR = 0;
    LPC_UART0->LCR = 0x83;
    LPC_UART0->DLL = mejor_divisor & 0xFF;
    LPC_UART0->DLM = (mejor_divisor >> 8) & 0xFF;
    LPC_UART0->FDR = (mejor_mul << 4) | mejor_divadd;
    LPC_UART0->LCR = 0x03;
    LPC_UART0->FCR = 0x07;
    LPC_UART0->TER = UART_TER_TXEN;
    LPC_UART0->IER = UART_IER_RBR | UART_IER_RLS;

    NVIC_SetPriority(UART0_IRQn, 2);
    NVIC_ClearPendingIRQ(UART0_IRQn);
    NVIC_EnableIRQ(UART0_IRQn);
}

static void uart0_enviar_texto(const char *texto)
{
    while (*texto != '\0') {
        while ((LPC_UART0->LSR & UART_LSR_THRE) == 0) {
        }

        LPC_UART0->THR = *texto;
        texto++;
    }
}

static void uart0_enviar_numero(uint32_t numero)
{
    char digitos[10];
    uint8_t cantidad = 0;

    if (numero == 0) {
        while ((LPC_UART0->LSR & UART_LSR_THRE) == 0) {
        }
        LPC_UART0->THR = '0';
        return;
    }

    while (numero != 0) {
        digitos[cantidad] = '0' + (numero % 10);
        cantidad++;
        numero /= 10;
    }

    while (cantidad != 0) {
        cantidad--;
        while ((LPC_UART0->LSR & UART_LSR_THRE) == 0) {
        }
        LPC_UART0->THR = digitos[cantidad];
    }
}

static void uart0_enviar_historial_adc(void)
{
    uint16_t mediciones[CANTIDAD_MEDICIONES];
    uint8_t cantidad;
    uint8_t inicio;
    uint8_t indice;
    uint8_t i;

    NVIC_DisableIRQ(DMA_IRQn);
    cantidad = adc_dma_cantidad;
    inicio = cantidad == CANTIDAD_MEDICIONES ? adc_dma_indice : 0;

    for (i = 0; i < cantidad; i++) {
        indice = (inicio + i) % CANTIDAD_MEDICIONES;
        mediciones[i] = (adc_dma_mediciones[indice] >> 4) & 0x0FFF;
    }

    NVIC_EnableIRQ(DMA_IRQn);

    uart0_enviar_texto(" | Ultimas 5 mediciones: ");

    if (cantidad == 0) {
        uart0_enviar_texto("sin datos");
        return;
    }

    for (i = 0; i < cantidad; i++) {
        if (i != 0) {
            uart0_enviar_texto(", ");
        }

        uart0_enviar_numero(mediciones[i]);
    }
}

static void uart0_enviar_estado(void)
{
    uart0_enviar_texto("Estado: ");

    if (estado == CERRADA) {
        uart0_enviar_texto("CERRADA");
    } else if (estado == ESPERANDO_PRESENCIA) {
        uart0_enviar_texto("ABIERTA - ESPERANDO PRESENCIA");
    } else {
        uart0_enviar_texto("ABIERTA - PRESENCIA DETECTADA");
    }

    uart0_enviar_texto(" | ADC: ");
    uart0_enviar_numero(adc_valor);
    uart0_enviar_historial_adc();
    uart0_enviar_texto(" | DMA: ");
    uart0_enviar_texto(dma_error == 0 ? "OK" : "ERROR");
    uart0_enviar_texto(" | EINT: ");
    uart0_enviar_texto(eint_habilitada != 0 ? "ON\r\n" : "OFF\r\n");
}

static void uart0_control_eint(uint8_t habilitar)
{
    eint_habilitada = habilitar;

    if (habilitar != 0) {
        if (estado == CERRADA) {
            EXTI_ClearEXTIFlag(EXTI_EINT0);
            NVIC_ClearPendingIRQ(EINT0_IRQn);
            NVIC_EnableIRQ(EINT0_IRQn);
        }

        uart0_enviar_texto("Comando ON recibido\r\n");
    } else {
        NVIC_DisableIRQ(EINT0_IRQn);
        EXTI_ClearEXTIFlag(EXTI_EINT0);
        NVIC_ClearPendingIRQ(EINT0_IRQn);
        uart0_enviar_texto("Comando OFF recibido\r\n");
    }

    uart_reporte_pendiente = 1;
}

static void uart0_procesar_dato(char dato)
{
    if (dato >= 'A' && dato <= 'Z') {
        dato += 'a' - 'A';
    }

    if (dato == '\r' || dato == '\n') {
        comando_uart_estado = 0;
        return;
    }

    if (comando_uart_estado == 0) {
        comando_uart_estado = dato == 'o' ? 1 : 0;
    } else if (comando_uart_estado == 1) {
        if (dato == 'n') {
            comando_uart_estado = 0;
            uart_comando_pendiente = 1;
        } else {
            comando_uart_estado = dato == 'f' ? 2 : 0;
        }
    } else {
        comando_uart_estado = 0;

        if (dato == 'f') {
            uart_comando_pendiente = 2;
        }
    }
}

static void abrir_barrera(void)
{
    servo_pulso_us = SERVO_ABIERTO_US;
    GPIO_ClearValue(0, LED_CERRADO_MASK);
    GPIO_SetValue(0, LED_ABIERTO_MASK);
    estado = ESPERANDO_PRESENCIA;

    TIM_ResetCounter(LPC_TIM3);
    TIM_ResetCounter(LPC_TIM2);
    TIM_Cmd(LPC_TIM3, ENABLE);
    TIM_Cmd(LPC_TIM2, ENABLE);
    uart_reporte_pendiente = 1;
}

static void cerrar_barrera(void)
{
    TIM_Cmd(LPC_TIM3, DISABLE);
    TIM_Cmd(LPC_TIM2, DISABLE);
    servo_pulso_us = SERVO_CERRADO_US;
    GPIO_ClearValue(0, LED_ABIERTO_MASK);
    GPIO_SetValue(0, LED_CERRADO_MASK);
    estado = CERRADA;

    if (eint_habilitada != 0) {
        EXTI_ClearEXTIFlag(EXTI_EINT0);
        NVIC_ClearPendingIRQ(EINT0_IRQn);
        NVIC_EnableIRQ(EINT0_IRQn);
    }

    uart_reporte_pendiente = 1;
}

void UART0_IRQHandler(void)
{
    uint32_t estado_linea = LPC_UART0->LSR;

    while ((estado_linea & UART_LSR_RDR) != 0) {
        uart0_procesar_dato((char)LPC_UART0->RBR);
        estado_linea = LPC_UART0->LSR;
    }
}

void EINT0_IRQHandler(void)
{
	test1++;
    if (estado == CERRADA && eint_habilitada != 0) {
        NVIC_DisableIRQ(EINT0_IRQn);
        iniciar_conversion_adc_dma();
    }
    EXTI_ClearEXTIFlag(EXTI_EINT0);
}

void DMA_IRQHandler(void)
{
    if (GPDMA_IntGetStatus(GPDMA_STAT_INTERR, DMA_CANAL_ADC) == SET) {
        GPDMA_ClearIntPending(GPDMA_STATCLR_INTERR, DMA_CANAL_ADC);
        GPDMA_ChannelCmd(DMA_CANAL_ADC, DISABLE);
        dma_error = 1;
        uart_reporte_pendiente = 1;

        if (eint_habilitada != 0) {
            EXTI_ClearEXTIFlag(EXTI_EINT0);
            NVIC_ClearPendingIRQ(EINT0_IRQn);
            NVIC_EnableIRQ(EINT0_IRQn);
        }

        return;
    }

    if (GPDMA_IntGetStatus(GPDMA_STAT_INTTC, DMA_CANAL_ADC) == RESET) {
        return;
    }

    GPDMA_ClearIntPending(GPDMA_STATCLR_INTTC, DMA_CANAL_ADC);
    GPDMA_ChannelCmd(DMA_CANAL_ADC, DISABLE);
    test2++;
    adc_valor = (adc_dma_mediciones[adc_dma_indice] >> 4) & 0x0FFF;
    adc_dma_indice = (adc_dma_indice + 1) % CANTIDAD_MEDICIONES;

    if (adc_dma_cantidad < CANTIDAD_MEDICIONES) {
        adc_dma_cantidad++;
    }

    if (adc_valor > UMBRAL_ADC) {
        abrir_barrera();
    } else {
        if (eint_habilitada != 0) {
            EXTI_ClearEXTIFlag(EXTI_EINT0);
            NVIC_ClearPendingIRQ(EINT0_IRQn);
            NVIC_EnableIRQ(EINT0_IRQn);
        }

        uart_reporte_pendiente = 1;
    }
}

void TIMER0_IRQHandler(void)
{
    if (TIM_GetIntStatus(LPC_TIM0, TIM_MR0_INT) == SET) {
        GPIO_ClearValue(0, SERVO_MASK);
        TIM_ClearIntPending(LPC_TIM0, TIM_MR0_INT);
    }

    if (TIM_GetIntStatus(LPC_TIM0, TIM_MR1_INT) == SET) {
        LPC_TIM0->MR0 = servo_pulso_us;
        GPIO_SetValue(0, SERVO_MASK);
        TIM_ClearIntPending(LPC_TIM0, TIM_MR1_INT);
    }
}

void TIMER1_IRQHandler(void)
{
    if (TIM_GetIntStatus(LPC_TIM1, TIM_MR0_INT) == SET) {
        TIM_ClearIntPending(LPC_TIM1, TIM_MR0_INT);
        uart_reporte_pendiente = 1;
    }
}

void TIMER3_IRQHandler(void)
{
    if (TIM_GetIntStatus(LPC_TIM3, TIM_MR0_INT) == SET) {
        TIM_ClearIntPending(LPC_TIM3, TIM_MR0_INT);

        if (estado == ESPERANDO_PRESENCIA &&
            (GPIO_ReadValue(0) & SENSOR_MASK) == 0) {
            estado = PRESENCIA_DETECTADA;
            uart_reporte_pendiente = 1;
        } else if (estado == PRESENCIA_DETECTADA &&
                   (GPIO_ReadValue(0) & SENSOR_MASK) != 0) {
            cerrar_barrera();
        }
    }
}

void TIMER2_IRQHandler(void)
{
    if (TIM_GetIntStatus(LPC_TIM2, TIM_MR0_INT) == SET) {
        TIM_ClearIntPending(LPC_TIM2, TIM_MR0_INT);
        if (estado != CERRADA) {
            cerrar_barrera();
        }
    }
}
